import java.lang.annotation.Retention;
import java.lang.annotation.RetentionPolicy;

// Step 1: Custom Annotation
@Retention(RetentionPolicy.RUNTIME)
@interface BookInfo {
    String genre();
    String addedBy();
}

// Step 2: Enum with display message
enum BookStatus {
    AVAILABLE("Available"),
    BORROWED("Borrowed"),
    RESERVED("Reserved"),
    LOST("Lost");

    private final String displayMessage;

    BookStatus(String displayMessage) {
        this.displayMessage = displayMessage;
    }

    public String getDisplayMessage() {
        return displayMessage;
    }
}

// Step 3: JavaBean
@BookInfo(genre = "Science Fiction", addedBy = "Admin")
class BookBean {

    private String title;
    private Double price;  // Wrapper class
    private BookStatus status;
    private int[] borrowCount = new int[12]; // 12 months

    // Getters & Setters
    public String getTitle() {
        return title;
    }

    public void setTitle(String title) {
        this.title = title;
    }

    public Double getPrice() {
        return price;
    }

    public void setPrice(Double price) {
        this.price = price;
    }

    public BookStatus getStatus() {
        return status;
    }

    public void setStatus(BookStatus status) {
        this.status = status;
    }

    public int getBorrowCount(int month) {
        return borrowCount[month];
    }

    public void setBorrowCount(int month, int count) {
        borrowCount[month] = count;
    }
}

// Step 4: Main Program
public class LibraryManagement {
    public static void main(String[] args) {

        // Create object
        BookBean book = new BookBean();
        book.setTitle("The Java Way");
        book.setPrice(29.99);
        book.setStatus(BookStatus.AVAILABLE);

        // Change status to BORROWED and print message
        book.setStatus(BookStatus.BORROWED);
        System.out.println("Status: " + book.getStatus().getDisplayMessage());

        // Set borrow count for months 1–3 (index 0–2)
        book.setBorrowCount(0, 5);
        book.setBorrowCount(1, 7);
        book.setBorrowCount(2, 3);

        // Reflection to read annotation
        if (book.getClass().isAnnotationPresent(BookInfo.class)) {
            BookInfo info = book.getClass().getAnnotation(BookInfo.class);
            System.out.println("Genre: " + info.genre());
            System.out.println("Added By: " + info.addedBy());
        }
    }
}
